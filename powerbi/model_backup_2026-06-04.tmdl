	table _Mesures
		lineageTag: 57f04fe2-3dc4-4be5-9465-4f2354cb4075

		measure \u0027Nb Membres Actifs\u0027 = \u0060\u0060\u0060
				
				COUNTROWS(
				    FILTER(\u0027public dim_membre\u0027, 
				        \u0027public dim_membre\u0027[est_membre_actif] = TRUE())
				)
				\u0060\u0060\u0060
			formatString: 0
			displayFolder: \uD83D\uDC65 Membres
			lineageTag: 8c684b3a-16fe-436d-a99a-a75262609da4

		measure \u0027Nb Adh\u00E9sions Saison Courante\u0027 =
				
				CALCULATE(
				    COUNTROWS(\u0027public fait_adhesion\u0027),
				    \u0027public dim_saison\u0027[est_saison_courante] = TRUE()
				)
			formatString: 0
			displayFolder: \uD83D\uDCCB Adh\u00E9sions
			lineageTag: af075e17-f6cf-493d-a400-4fcfde9ddc93

		measure \u0027Nb Encadrants\u0027 =
				
				CALCULATE(
				    COUNTROWS(FILTER(\u0027public fait_adhesion\u0027,
				        \u0027public fait_adhesion\u0027[is_encadrant] = TRUE()
				    )),
				    FILTER(\u0027public dim_saison\u0027, \u0027public dim_saison\u0027[est_saison_courante] = TRUE())
				)
			formatString: 0
			displayFolder: \uD83D\uDC65 Membres
			lineageTag: 9e8463fe-ad13-4935-b4b0-1d8a912e6381

		measure \u0027\u00C2ge Moyen Membres\u0027 =
				
				AVERAGE(\u0027public dim_membre\u0027[age])
			displayFolder: \uD83D\uDC65 Membres
			lineageTag: f6033ac8-f402-4362-aa10-55ea233bad4a

			annotation PBI_FormatHint = {\u0022isGeneralNumber\u0022:true}

		measure \u0027Nb Nouveaux Membres\u0027 = \u0060\u0060\u0060
				
				CALCULATE(
				    DISTINCTCOUNT(\u0027public fait_adhesion\u0027[membre_id]),
				    \u0027public fait_adhesion\u0027[saison_id] = 2026,
				    NOT(\u0027public fait_adhesion\u0027[membre_id] 
				        IN CALCULATETABLE(
				            VALUES(\u0027public fait_adhesion\u0027[membre_id]),
				            \u0027public fait_adhesion\u0027[saison_id] \u003C 2026
				        )
				    )
				)
				\u0060\u0060\u0060
			formatString: 0
			displayFolder: \uD83D\uDC65 Membres
			lineageTag: 462c2ae2-622c-4be7-ad72-f1c6de906d95

		measure \u0027Taux Dossier Complet\u0027 =
				
				VAR saison_courante = MAXX(ALL(\u0027public fait_adhesion\u0027), \u0027public fait_adhesion\u0027[saison_id])
				VAR adhesions_saison =
				    FILTER(\u0027public fait_adhesion\u0027, \u0027public fait_adhesion\u0027[saison_id] = saison_courante)
				RETURN
				DIVIDE(
				    COUNTROWS(FILTER(adhesions_saison, \u0027public fait_adhesion\u0027[statut_dossier] = \u0022Complet\u0022)),
				    COUNTROWS(adhesions_saison)
				)
			formatString: 0.0\\ %;-0.0\\ %;0.0\\ %
			displayFolder: \uD83D\uDCCB Adh\u00E9sions
			lineageTag: e42d96ad-3350-4c29-8ecf-14700f812a41

		measure \u0027Nb Dossiers Incomplets\u0027 =
				
				VAR saison_courante = MAXX(ALL(\u0027public fait_adhesion\u0027), \u0027public fait_adhesion\u0027[saison_id])
				RETURN
				COUNTROWS(
				    FILTER(\u0027public fait_adhesion\u0027,
				        \u0027public fait_adhesion\u0027[saison_id] = saison_courante
				        \u0026\u0026 \u0027public fait_adhesion\u0027[statut_dossier] \u003C\u003E \u0022Complet\u0022
				    )
				)
			formatString: 0
			displayFolder: \uD83D\uDCCB Adh\u00E9sions
			lineageTag: 849a778b-72ff-4abf-8894-d9249cc48405

		measure \u0027Nb Sorties\u0027 =
				
				DISTINCTCOUNT(\u0027public fait_participation\u0027[sortie_id])
			formatString: 0
			displayFolder: \uD83E\uDD3F Sorties
			lineageTag: 3c8f1950-7188-4714-99c6-d2937fed81f8

		measure \u0027Nb Participations\u0027 =
				
				SUM(\u0027public fait_participation\u0027[nb_inscriptions])
			formatString: 0
			displayFolder: \uD83E\uDD3F Sorties
			lineageTag: b56a839b-41b3-4a5c-9aa5-41186a216edb

		measure \u0027Choix Sondage\u0027 =
				
				COALESCE(
				    CALCULATE(MAX(\u0027public fait_vote\u0027[option_label])),
				    \u0022Non r\u00E9pondu\u0022
				)
			displayFolder: \uD83D\uDC65 Membres
			lineageTag: 9f21b6f1-08d9-453d-ad32-f02da9c588b2

		column Vide
			isHidden
			lineageTag: 86d54d35-1927-4117-8ffc-3671788df834
			summarizeBy: none
			isNameInferred
			sourceColumn: [Vide]

			annotation SummarizationSetBy = Automatic

		partition _Mesures = calculated
			mode: import
			source = DATATABLE(\u0022Vide\u0022, STRING, {{\u0022\u0022}})

		annotation PBI_Id = 2009e0e5eab944818413ceefda304c77

